{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://raw.githubusercontent.com/budak7273/ContentLib_Documentation/main/JsonSchemas/CL_RGBA_Color.json",
    "title": "RGBA Color",
    "description": "Unreal 'Red Green Blue Alpha' color",
    "$comment": "This file does not represent ContentLib asset type! It's a resource used by other JSON Schemas.",
    "type": "object",
    "additionalProperties": false,
    "required": [
        "r",
        "g",
        "b",
        "a"
    ],
    "properties": {
        "r": {
            "type": "integer",
            "description": "Red channel",
            "minimum": 0,
            "maximum": 255
        },
        "g": {
            "type": "integer",
            "description": "Green channel",
            "minimum": 0,
            "maximum": 255
        },
        "b": {
            "type": "integer",
            "description": "Blue channel",
            "minimum": 0,
            "maximum": 255
        },
        "a": {
            "type": "integer",
            "description": "Alpha (opacity) channel. 255 is fully opaque. 0 is fully transparent.",
            "minimum": 0,
            "maximum": 255
        }
    },
    "examples": [
        {
            "r": 255,
            "g": 0,
            "b": 255,
            "a": 255
        }
    ]
}